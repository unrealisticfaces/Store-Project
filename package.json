{
  "name": "store-manager-pos",
  "version": "1.0.0",
  "description": "Enterprise POS and Inventory System",
  "main": "electron/main.cjs",
  "author": "Store Admin",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "serve": "vite preview",
    "electron:start": "electron .",
    "package": "npm run build && electron-builder --win"
  },
  "dependencies": {
    "@tabler/icons-react": "^3.0.0",
    "apexcharts": "^3.49.0",
    "react": "^18.2.0",
    "react-apexcharts": "^1.4.1",
    "react-dom": "^18.2.0",
    "sqlite3": "^5.1.7"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "electron": "^30.0.0",
    "electron-builder": "^24.13.3",
    "vite": "^5.2.0"
  },
  "build": {
    "appId": "com.storemanager.pos",
    "productName": "Store Manager POS",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Store Manager POS",
      "installerIcon": "public/favicon.svg",
      "uninstallerIcon": "public/favicon.svg",
      "uninstallDisplayName": "Uninstall Store Manager POS"
    }
  }
}